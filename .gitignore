# Dependencias y caché de paquetes (Vercel instala todo en el build)
node_modules/
.pnpm-store/

# Build de Next.js (Vercel genera su propio .next)
.next/
out/
build/
dist/

# TypeScript — artefactos locales de compilación
*.tsbuildinfo

# Vercel
.vercel/

# Variables de entorno locales (secretos; en Vercel se configuran en el dashboard)
.env
.env*.local
.env.development
.env.production

# Logs y depuración
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Sistema operativo
.DS_Store
Thumbs.db

# Editores e IDE (preferencias locales, no afectan el deploy)
.idea/
.vscode/
*.swp
*.swo

# Testing y cobertura
coverage/
.nyc_output/

# Turborepo / cachés opcionales
.turbo/

# Certificados locales
*.pem

# v0 sandbox (archivos internos de la plantilla)
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts
.snowflake/
.v0-trash/
